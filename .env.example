# Qwen/DashScope API配置
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 代理配置（直连可用时注释掉）
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# 模型配置 - 根据任务难度选择
# vision: Qwen3-VL 图片识别（支持多模态）
# medium/hard/expert: Qwen-3.5 条款分析、最终结论
MODEL_VISION=qwen-vl-plus
MODEL_SIMPLE=qwen-plus
MODEL_MEDIUM=qwen-plus
MODEL_HARD=qwen-plus
MODEL_EXPERT=qwen-plus

# 视觉模型切换: true=Qwen/DashScope, false=OpenRouter/Gemini（需开VPN）
USE_QWEN_VISION=true

# OpenRouter配置（USE_QWEN_VISION=false 时生效）
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_VISION_OPENROUTER=google/gemini-2.5-pro-preview
# 模型参数
TEMPERATURE=0.1
TIMEOUT=180

# OCR缓存配置
OCR_CACHE_ENABLED=true
OCR_CACHE_DIR=.cache/ocr
OCR_CACHE_EXPIRE_DAYS=30
  
# 文档处理缓存配置
DOC_CACHE_ENABLED=true
DOC_CACHE_DIR=.cache/docs
DOC_CACHE_EXPIRE_DAYS=30

# 审核配置
MAX_RETRY=3
SINGLE_ITEM_LIMIT=1000
DEPRECIATION_RATE=0.01

# 航班数据源配置
FLIGHT_DATA_PROVIDER=variflight
VARIFLIGHT_API_KEY=sk-vf4J85_Xri2pdDh6iwD54lcivtsdvo-mT2QKqwEpx7s
AVIATIONSTACK_API_KEY=6e5cc78eb3f5e8977f6d58dfbe4b6a45
