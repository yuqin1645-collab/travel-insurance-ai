MATERIAL_CHECKLIST_URL=https://www.kdocs.cn/l/ch8Qrro1EkYQ # 材料清单URL
CLAIMS_DATA_DIR=claims_data # 原始索赔数据目录
REVIEW_RESULTS_DIR=review_results # 审核结果目录
PROMPTS_DIR=prompts # 审核提示语目录
