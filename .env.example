# =============================================
# 生产化调度配置
# =============================================
# 下载间隔（秒），默认1小时
DOWNLOAD_INTERVAL=3600

# 审核间隔（秒），默认10分钟
REVIEW_INTERVAL=600

# 补件检查间隔（秒），默认30分钟
SUPPLEMENTARY_CHECK_INTERVAL=1800

# 清理间隔（秒），默认24小时
CLEANUP_INTERVAL=86400

# =============================================
# 重试配置
# =============================================
MAX_DOWNLOAD_RETRIES=3
MAX_REVIEW_RETRIES=2
RETRY_BACKOFF_BASE=2

# =============================================
# 补件配置
# =============================================
# 补件截止时间（小时）
SUPPLEMENTARY_DEADLINE_HOURS=24

# 最大补件次数
MAX_SUPPLEMENTARY_COUNT=3

# 补件提醒时间（小时前）
SUPPLEMENTARY_REMINDER_HOURS=6

# =============================================
# 前端API配置
# =============================================
FRONTEND_API_URL=https://nanyan.sites.sfcrmapps.cn/services/apexrest/Rest_AI_CLaim_Conclusion
FRONTEND_API_KEY=
FRONTEND_TIMEOUT=30

# =============================================
# 材料检查模式
# =============================================
MATERIAL_CHECK_MODE=vision
VISION_MAX_ATTACHMENTS=20
