# OpenRouter API配置
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 模型配置 - 根据任务难度选择
MODEL_SIMPLE=anthropic/claude-3-haiku
MODEL_MEDIUM=anthropic/claude-3.5-sonnet
MODEL_HARD=anthropic/claude-3.5-sonnet
MODEL_EXPERT=anthropic/claude-3-opus

# 模型参数
TEMPERATURE=0.1
MAX_TOKENS=4000
TIMEOUT=60

# OCR配置
# 支持的提供商: tesseract(本地), aliyun(阿里云), tencent(腾讯云), baidu(百度), mock(模拟测试)
OCR_PROVIDER=tesseract
# Tesseract路径 (本地OCR,免费)
TESSERACT_PATH=D:\app\tools\other\Tesseract\tesseract.exe
# 云服务OCR密钥 (如使用云服务)
# 阿里云: AccessKey ID 和 AccessKey Secret
# 腾讯云: SecretId 和 SecretKey
# 百度: API Key 和 Secret Key
OCR_API_KEY=your_ocr_api_key_here
OCR_API_SECRET=your_ocr_api_secret_here

# 审核配置
MAX_RETRY=3
SINGLE_ITEM_LIMIT=1000
DEPRECIATION_RATE=0.01

# 文件路径
POLICY_TERMS_DIR=static/旅行险条款
MATERIAL_CHECKLIST_URL=https://www.kdocs.cn/l/ch8Qrro1EkYQ
CLAIMS_DATA_DIR=claims_data
REVIEW_RESULTS_DIR=review_results
PROMPTS_DIR=prompts

# 数据库配置(用于同步审核结果到nlpp)
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=ai
