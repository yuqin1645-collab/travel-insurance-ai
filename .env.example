# =============================================
# 生产化调度配置
# =============================================
# 下载间隔（秒），默认1小时
DOWNLOAD_INTERVAL=3600

# 审核间隔（秒），默认10分钟
REVIEW_INTERVAL=600

# 补件检查间隔（秒），默认30分钟
SUPPLEMENTARY_CHECK_INTERVAL=1800

# 清理间隔（秒），默认24小时
CLEANUP_INTERVAL=86400

# =============================================
# 重试配置
# =============================================
MAX_DOWNLOAD_RETRIES=3 # 下载重试次数
MAX_REVIEW_RETRIES=2  # 审核重试次数
MAX_SUPPLEMENTARY_RETRIES=2 # 补件重试次数
RETRY_BACKOFF_BASE=2 # 重试基础倍数（指数退避）
RETRY_BACKOFF_MAX=30 # 重试最大等待时间（秒）

# =============================================
# 补件配置
# =============================================
# 补件截止时间（小时）
SUPPLEMENTARY_DEADLINE_HOURS=24

# 最大补件次数
MAX_SUPPLEMENTARY_COUNT=3

# 补件提醒时间（小时前）
SUPPLEMENTARY_REMINDER_HOURS=6

# =============================================
# 前端API配置
# =============================================
FRONTEND_API_URL=https://nanyan.sites.sfcrmapps.cn/services/apexrest/Rest_AI_CLaim_Conclusion   # 前端API URL
FRONTEND_API_KEY=  
FRONTEND_TIMEOUT=30 # 秒


# =============================================
# 材料检查模式
# =============================================
MATERIAL_CHECK_MODE=vision # 可选值：vision（使用Qwen/DashScope的视觉能力进行材料检查），simple（仅使用文本分析进行材料检查）
VISION_MAX_ATTACHMENTS=20 # Vision模式下的最大附件数量

# Vision concurrency and retry settings
VISION_GLOBAL_CONCURRENCY=6 # 全局并发限制
VISION_RETRY_NETWORK_MAX_ATTEMPTS=3 # 网络错误重试次数
VISION_RETRY_JSON_MAX_ATTEMPTS=2 # JSON解析错误重试次数
VISION_RETRY_BASE_DELAY=2.0 # 重试基础延迟（秒）
VISION_RETRY_MAX_DELAY=20.0 # 重试最大延迟（秒）
VISION_RETRY_JITTER=0.35 # 重试抖动（0-1之间，增加随机性以避免重试风暴）
VISION_MAX_ATTACHMENTS=10 # Vision模式下的最大附件数量